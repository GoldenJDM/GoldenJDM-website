<style>
  :root {
    --ink: #0b0b0f;
    --ivory: #e9e9ef;
    --mist: #a7a7b3;
    --orchid: #a78bfa;
    --blush: #f472b6;
  }

  * { -webkit-font-smoothing: antialiased; -moz-osx-font-smoothing: grayscale; }
  html { scroll-behavior: smooth; }
  body {
    background: var(--ink);
    color: var(--ivory);
    font-family: 'Inter', system-ui, sans-serif;
    overflow-x: hidden;
    cursor: none;
  }
  body.lang-fa { font-family: 'Vazirmatn', system-ui, sans-serif; }
  body.lang-fa * { font-family: 'Vazirmatn', system-ui, sans-serif !important; }

  /* Custom cursor */
  .cursor-dot, .cursor-ring {
    position: fixed; top: 0; left: 0; pointer-events: none; z-index: 9999;
    border-radius: 50%; transform: translate(-50%, -50%);
    transition: opacity 0.3s ease;
  }
  .cursor-dot { width: 6px; height: 6px; background: var(--orchid); box-shadow: 0 0 12px var(--orchid); }
  .cursor-ring {
    width: 38px; height: 38px; border: 1.5px solid rgba(167,139,250,0.4);
    transition: transform 0.15s ease, width 0.3s ease, height 0.3s ease, border-color 0.3s ease;
  }
  .cursor-ring.hover { width: 60px; height: 60px; border-color: var(--blush); }
  @media (max-width: 768px) { .cursor-dot, .cursor-ring { display: none; } body { cursor: auto; } }

  /* Noise overlay */
  .noise {
    position: fixed; inset: 0; pointer-events: none; z-index: 100;
    opacity: 0.04; mix-blend-mode: overlay;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
  }

  /* Scroll progress */
  .scroll-progress {
    position: fixed; top: 0; left: 0; height: 2px; width: 0%;
    background: linear-gradient(90deg, var(--orchid), var(--blush));
    z-index: 200; transition: width 0.1s linear;
    box-shadow: 0 0 10px var(--orchid);
  }
  html[dir="rtl"] .scroll-progress { left: auto; right: 0; }

  /* Gradient orbs */
  .orb {
    position: absolute; border-radius: 50%; filter: blur(120px); opacity: 0.35;
    pointer-events: none; will-change: transform;
  }

  /* Glassmorphism */
  .glass {
    background: rgba(20, 20, 28, 0.55);
    backdrop-filter: blur(20px) saturate(140%);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    border: 1px solid rgba(233, 233, 239, 0.08);
  }

  /* Reveal animations */
  .reveal { opacity: 0; transform: translateY(40px); transition: opacity 1s cubic-bezier(0.22, 1, 0.36, 1), transform 1s cubic-bezier(0.22, 1, 0.36, 1); }
  .reveal.in { opacity: 1; transform: translateY(0); }
  .reveal-stagger > * { opacity: 0; transform: translateY(30px); transition: opacity 0.8s ease, transform 0.8s ease; }
  .reveal-stagger.in > *:nth-child(1) { transition-delay: 0.05s; }
  .reveal-stagger.in > *:nth-child(2) { transition-delay: 0.15s; }
  .reveal-stagger.in > *:nth-child(3) { transition-delay: 0.25s; }
  .reveal-stagger.in > *:nth-child(4) { transition-delay: 0.35s; }
  .reveal-stagger.in > *:nth-child(5) { transition-delay: 0.45s; }
  .reveal-stagger.in > *:nth-child(6) { transition-delay: 0.55s; }
  .reveal-stagger.in > * { opacity: 1; transform: translateY(0); }

  /* Hero text reveal */
  .word { display: inline-block; overflow: hidden; vertical-align: bottom; }
  .word span { display: inline-block; transform: translateY(110%); transition: transform 1.1s cubic-bezier(0.77, 0, 0.175, 1); }
  .word.in span { transform: translateY(0); }

  /* Neon underline */
  .neon-underline { position: relative; }
  .neon-underline::after {
    content: ''; position: absolute; bottom: -6px; left: 0; height: 2px; width: 0;
    background: linear-gradient(90deg, var(--orchid), var(--blush));
    transition: width 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    box-shadow: 0 0 10px var(--orchid);
  }
  .neon-underline:hover::after { width: 100%; }
  html[dir="rtl"] .neon-underline::after { left: auto; right: 0; }

  /* Button glow */
  .btn-glow {
    position: relative; overflow: hidden;
    background: linear-gradient(135deg, var(--orchid), var(--blush));
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 0 0 rgba(167,139,250,0);
  }
  .btn-glow:hover { transform: translateY(-2px); box-shadow: 0 10px 40px -10px rgba(167,139,250,0.6); }
  .btn-glow::before {
    content: ''; position: absolute; inset: 0;
    background: linear-gradient(135deg, transparent, rgba(255,255,255,0.3), transparent);
    transform: translateX(-100%); transition: transform 0.6s ease;
  }
  .btn-glow:hover::before { transform: translateX(100%); }

  /* Project card */
  .project-card {
    position: relative; overflow: hidden;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1), border-color 0.4s ease;
  }
  .project-card:hover { transform: translateY(-8px); border-color: rgba(167,139,250,0.4); }
  .project-card .img-wrap { overflow: hidden; }
  .project-card .img-wrap img { transition: transform 1.2s cubic-bezier(0.22, 1, 0.36, 1), filter 0.6s ease; }
  .project-card:hover .img-wrap img { transform: scale(1.08); filter: brightness(1.1); }
  .project-card .overlay {
    position: absolute; inset: 0; opacity: 0;
    background: linear-gradient(180deg, transparent 40%, rgba(11,11,15,0.95) 100%);
    transition: opacity 0.5s ease;
  }
  .project-card:hover .overlay { opacity: 1; }

  /* Marquee */
  .marquee { display: flex; overflow: hidden; mask-image: linear-gradient(90deg, transparent, #000 10%, #000 90%, transparent); }
  .marquee-track { display: flex; animation: scroll-x 40s linear infinite; flex-shrink: 0; }
  @keyframes scroll-x { to { transform: translateX(-50%); } }
  html[dir="rtl"] .marquee-track { animation-direction: reverse; }

  /* Mobile menu */
  .mobile-menu {
    position: fixed; inset: 0; z-index: 150;
    background: rgba(11,11,15,0.98); backdrop-filter: blur(30px);
    transform: translateY(-100%); transition: transform 0.7s cubic-bezier(0.77, 0, 0.175, 1);
  }
  .mobile-menu.open { transform: translateY(0); }
  .mobile-menu a {
    display: block; font-size: 2.5rem; font-weight: 600; padding: 1rem 0;
    opacity: 0; transform: translateY(20px); transition: opacity 0.4s ease, transform 0.4s ease, color 0.3s ease;
  }
  .mobile-menu.open a { opacity: 1; transform: translateY(0); }
  .mobile-menu.open a:nth-child(1) { transition-delay: 0.1s; }
  .mobile-menu.open a:nth-child(2) { transition-delay: 0.18s; }
  .mobile-menu.open a:nth-child(3) { transition-delay: 0.26s; }
  .mobile-menu.open a:nth-child(4) { transition-delay: 0.34s; }
  .mobile-menu.open a:nth-child(5) { transition-delay: 0.42s; }
  .mobile-menu a:hover { color: var(--orchid); }

  /* Form */
  .input-field {
    background: rgba(20,20,28,0.6); border: 1px solid rgba(233,233,239,0.1);
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }
  .input-field:focus {
    outline: none; border-color: var(--orchid);
    box-shadow: 0 0 0 3px rgba(167,139,250,0.15);
  }

  /* Tag */
  .tag {
    display: inline-flex; align-items: center; gap: 0.4rem;
    padding: 0.35rem 0.85rem; border-radius: 999px;
    background: rgba(167,139,250,0.08); border: 1px solid rgba(167,139,250,0.2);
    font-size: 0.75rem; letter-spacing: 0.05em; text-transform: uppercase;
    color: var(--orchid);
  }

  /* Link card */
  .link-card {
    transition: transform 0.4s ease, border-color 0.4s ease, background 0.4s ease;
  }
  .link-card:hover { transform: translateX(6px); border-color: rgba(244,114,182,0.4); background: rgba(244,114,182,0.04); }
  html[dir="rtl"] .link-card:hover { transform: translateX(-6px); }

  /* Floating badge */
  .float-badge {
    animation: float 6s ease-in-out infinite;
  }
  @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-12px); } }

  /* Hero image parallax */
  .hero-img {
    animation: heroFloat 8s ease-in-out infinite;
  }
  @keyframes heroFloat { 0%,100% { transform: translateY(0) scale(1); } 50% { transform: translateY(-20px) scale(1.02); } }

  /* Selection */
  ::selection { background: var(--orchid); color: var(--ink); }

  /* Scrollbar */
  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: var(--ink); }
  ::-webkit-scrollbar-thumb { background: linear-gradient(var(--orchid), var(--blush)); border-radius: 4px; }

  /* Pulse dot */
  .pulse-dot { position: relative; }
  .pulse-dot::before {
    content: ''; position: absolute; inset: 0; border-radius: 50%;
    background: var(--blush); animation: pulse 2s ease-out infinite;
  }
  @keyframes pulse { 0% { transform: scale(1); opacity: 0.7; } 100% { transform: scale(3); opacity: 0; } }

  /* Divider line */
  .divider {
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(233,233,239,0.15), transparent);
  }

  /* Nav link active indicator */
  .nav-link { position: relative; }
  .nav-link.active::before {
    content: ''; position: absolute; top: 50%; left: -14px; width: 6px; height: 6px;
    background: var(--orchid); border-radius: 50%; transform: translateY(-50%);
    box-shadow: 0 0 10px var(--orchid);
  }
  html[dir="rtl"] .nav-link.active::before { left: auto; right: -14px; }

  /* Typing cursor */
  .typing::after {
    content: ''; display: inline-block; width: 2px; height: 1em; background: var(--orchid);
    margin-left: 4px; animation: blink 1s step-end infinite; vertical-align: text-bottom;
  }
  @keyframes blink { 50% { opacity: 0; } }
</style>
</head>

